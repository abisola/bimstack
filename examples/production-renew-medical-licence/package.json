{
  "name": "renew-medical-licence-production",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready front-end for the medical-licence renewal service, with regression, accessibility, security, and load tests. Generated by bimstack /bimstack:productionise.",
  "scripts": {
    "serve": "./scripts/serve.sh",
    "audit": "./scripts/audit.sh",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:a11y": "playwright test tests/accessibility",
    "test:security": "playwright test tests/security && ./tests/security/headers.sh ${BASE_URL:-http://localhost:8080}",
    "test:load:peak": "k6 run tests/load/peak.js",
    "test:load:soak": "k6 run tests/load/soak.js",
    "test:all": "./scripts/run-all.sh",
    "report:open": "open reports/playwright-html/index.html"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": "github:abisola/bimstack",
  "keywords": [
    "alpha.gov.bb",
    "govtech-barbados",
    "production",
    "accessibility",
    "security",
    "playwright",
    "k6"
  ]
}
